@@ -0,0 +1,69 @@
+import { db } from "@workspace/db";
+import { auditLogsTable } from "@workspace/db/schema";
+import { logger } from "./logger.js";
+
+export type AuditActorType = "staff" | "client" | "automation" | "system";
+
+export interface AuditLogInput {
+  actorType?: AuditActorType;
+  actorUserId?: string | null;
+  actorEmail?: string | null;
+  action: string;
+  tableName: string;
+  recordId?: string | null;
+  before?: unknown;
+  after?: unknown;
+  ipAddress?: string | null;
+  userAgent?: string | null;
+  requestId?: string | null;
+  statusCode?: number | null;
+}
+
+const SENSITIVE_KEYS = new Set([
+  "password",
+  "passwordHash",
+  "token",
+  "accessToken",
+  "refreshToken",
+  "secret",
+  "apiKey",
+  "authorization",
+  "cookie",
+  "sessionSecret",
+]);
+
+function redact(value: unknown): unknown {
+  if (Array.isArray(value)) return value.map(redact);
+  if (!value || typeof value !== "object") return value;
+
+  const out: Record<string, unknown> = {};
+  for (const [key, child] of Object.entries(value as Record<string, unknown>)) {
+    if (SENSITIVE_KEYS.has(key) || key.toLowerCase().includes("password") || key.toLowerCase().includes("secret")) {
+      out[key] = "[REDACTED]";
+    } else {
+      out[key] = redact(child);
+    }
+  }
+  return out;
+}
+
+export async function writeAuditLog(input: AuditLogInput): Promise<void> {
+  try {
+    await db.insert(auditLogsTable).values({
+      actorType: input.actorType ?? "staff",
+      actorUserId: input.actorUserId ?? null,
+      actorEmail: input.actorEmail ?? null,
+      action: input.action,
+      tableName: input.tableName,
+      recordId: input.recordId ?? null,
+      before: input.before === undefined ? null : redact(input.before),
+      after: input.after === undefined ? null : redact(input.after),
+      ipAddress: input.ipAddress ?? null,
+      userAgent: input.userAgent ?? null,
+      requestId: input.requestId ?? null,
+      statusCode: input.statusCode ?? null,
+    });
+  } catch (error) {
+    // Never break the business workflow because audit logging failed.
+    logger.error({ err: error, action: input.action, tableName: input.tableName }, "failed to write audit log");
+  }
+}
