--- /mnt/data/aum_current/artifacts/api-server/src/routes/data-imports.ts	1970-01-01 00:00:00.000000000 +0000
+++ /mnt/data/aum_import_work/artifacts/api-server/src/routes/data-imports.ts	2026-06-24 17:02:56.316796264 +0000
@@ -0,0 +1,386 @@
+import { Router } from "express";
+import { and, desc, eq } from "drizzle-orm";
+import { db } from "@workspace/db";
+import {
+  clientsTable,
+  followUpsTable,
+  importBatchesTable,
+  importRowsTable,
+  inventoryItemsTable,
+  invoiceItemsTable,
+  invoicesTable,
+  paymentsTable,
+  quotationItemsTable,
+  quotationsTable,
+  serviceCategoriesTable,
+} from "@workspace/db/schema";
+import { authenticate } from "../middleware/auth.js";
+
+const router = Router();
+
+type ImportSourceType =
+  | "CLIENTS_CSV"
+  | "QUOTATIONS_CSV"
+  | "INVOICES_CSV"
+  | "INVOICE_ITEMS_CSV"
+  | "INVENTORY_CSV"
+  | "SERVICE_CATEGORIES_CSV"
+  | "TASK_BOARD_CSV"
+  | "TASK_BOARD_PDF";
+
+type CsvRow = Record<string, string>;
+
+function parseCsv(content: string): CsvRow[] {
+  const rows: string[][] = [];
+  let field = "";
+  let row: string[] = [];
+  let quoted = false;
+
+  for (let i = 0; i < content.length; i += 1) {
+    const char = content[i];
+    const next = content[i + 1];
+    if (quoted) {
+      if (char === '"' && next === '"') {
+        field += '"';
+        i += 1;
+      } else if (char === '"') {
+        quoted = false;
+      } else {
+        field += char;
+      }
+      continue;
+    }
+    if (char === '"') {
+      quoted = true;
+    } else if (char === ",") {
+      row.push(field.trim());
+      field = "";
+    } else if (char === "\n") {
+      row.push(field.trim());
+      rows.push(row);
+      row = [];
+      field = "";
+    } else if (char !== "\r") {
+      field += char;
+    }
+  }
+  if (field || row.length) {
+    row.push(field.trim());
+    rows.push(row);
+  }
+
+  const [headers = [], ...body] = rows.filter((r) => r.some((cell) => cell.trim() !== ""));
+  const normalizedHeaders = headers.map((header, index) => normalizeHeader(header || `column_${index + 1}`));
+  return body.map((values) => {
+    const out: CsvRow = {};
+    normalizedHeaders.forEach((header, index) => {
+      out[header] = values[index]?.trim() ?? "";
+    });
+    return out;
+  });
+}
+
+function normalizeHeader(header: string): string {
+  return header
+    .trim()
+    .toLowerCase()
+    .replace(/[^a-z0-9]+/g, "_")
+    .replace(/^_+|_+$/g, "");
+}
+
+function pick(row: CsvRow, keys: string[]): string | undefined {
+  for (const key of keys) {
+    const value = row[normalizeHeader(key)] ?? row[key];
+    if (value && value.trim() !== "") return value.trim();
+  }
+  return undefined;
+}
+
+function money(value: string | undefined): string {
+  if (!value) return "0";
+  const cleaned = value.replace(/[^0-9.-]/g, "");
+  if (!cleaned || Number.isNaN(Number(cleaned))) return "0";
+  return Number(cleaned).toFixed(2);
+}
+
+function intValue(value: string | undefined, fallback = 0): number {
+  if (!value) return fallback;
+  const cleaned = value.replace(/[^0-9-]/g, "");
+  const parsed = Number.parseInt(cleaned, 10);
+  return Number.isFinite(parsed) ? parsed : fallback;
+}
+
+async function findOrCreateClient(clientName: string, actorUserId?: string) {
+  const name = clientName.trim() || "Unknown Legacy Client";
+  const [existing] = await db.select().from(clientsTable).where(eq(clientsTable.clientName, name)).limit(1);
+  if (existing) return existing;
+  const [created] = await db.insert(clientsTable).values({
+    clientName: name,
+    clientType: "LEGACY_IMPORT",
+    notes: actorUserId ? `Created by legacy import by ${actorUserId}` : "Created by legacy import",
+  }).returning();
+  return created;
+}
+
+function statusForQuotation(value?: string): "DRAFT" | "PENDING_APPROVAL" | "APPROVED" | "SENT" | "ACCEPTED" | "REJECTED" | "EXPIRED" {
+  const normalized = (value ?? "").toUpperCase();
+  if (normalized.includes("ACCEPT")) return "ACCEPTED";
+  if (normalized.includes("APPROV")) return "APPROVED";
+  if (normalized.includes("REJECT")) return "REJECTED";
+  if (normalized.includes("SENT")) return "SENT";
+  if (normalized.includes("EXPIRE")) return "EXPIRED";
+  return "DRAFT";
+}
+
+function statusForInvoice(value?: string, total = 0, paid = 0): "DRAFT" | "SENT" | "PARTIALLY_PAID" | "PAID" | "OVERDUE" | "CANCELLED" {
+  const normalized = (value ?? "").toUpperCase();
+  if (normalized.includes("CANCEL")) return "CANCELLED";
+  if (normalized.includes("OVERDUE")) return "OVERDUE";
+  if (paid >= total && total > 0) return "PAID";
+  if (paid > 0) return "PARTIALLY_PAID";
+  if (normalized.includes("DRAFT")) return "DRAFT";
+  return "SENT";
+}
+
+function classifyTarget(sourceType: ImportSourceType): string {
+  const map: Record<ImportSourceType, string> = {
+    CLIENTS_CSV: "clients",
+    QUOTATIONS_CSV: "quotations",
+    INVOICES_CSV: "invoices",
+    INVOICE_ITEMS_CSV: "invoice_items",
+    INVENTORY_CSV: "inventory_items",
+    SERVICE_CATEGORIES_CSV: "service_categories",
+    TASK_BOARD_CSV: "follow_ups",
+    TASK_BOARD_PDF: "follow_ups",
+  };
+  return map[sourceType];
+}
+
+async function processRow(sourceType: ImportSourceType, row: CsvRow, rowNumber: number, actorUserId?: string) {
+  if (sourceType === "TASK_BOARD_PDF") {
+    return {
+      targetTable: "follow_ups",
+      status: "REVIEW_REQUIRED" as const,
+      mappedData: { note: "PDF task-board rows need OCR/manual extraction before automated import.", row },
+      targetRecordId: null,
+    };
+  }
+
+  if (sourceType === "CLIENTS_CSV") {
+    const clientName = pick(row, ["client_name", "client", "customer", "name", "company"]);
+    if (!clientName) throw new Error("Missing client name");
+    const [client] = await db.insert(clientsTable).values({
+      clientName,
+      clientType: pick(row, ["client_type", "type"]) ?? "LEGACY",
+      contactPerson: pick(row, ["contact_person", "contact", "person"]),
+      phone: pick(row, ["phone", "mobile", "telephone"]),
+      email: pick(row, ["email", "mail"]),
+      location: pick(row, ["location", "area", "site"]),
+      address: pick(row, ["address"]),
+      kraPin: pick(row, ["kra_pin", "kra"]),
+      notes: pick(row, ["notes", "remark", "remarks"]),
+    }).returning();
+    return { targetTable: "clients", status: "IMPORTED" as const, mappedData: client, targetRecordId: client.id };
+  }
+
+  if (sourceType === "SERVICE_CATEGORIES_CSV") {
+    const name = pick(row, ["name", "category", "service_category", "service"]);
+    if (!name) throw new Error("Missing service category name");
+    const [existing] = await db.select().from(serviceCategoriesTable).where(eq(serviceCategoriesTable.name, name)).limit(1);
+    if (existing) return { targetTable: "service_categories", status: "SKIPPED" as const, mappedData: existing, targetRecordId: existing.id };
+    const [category] = await db.insert(serviceCategoriesTable).values({ name, description: pick(row, ["description", "notes"]) }).returning();
+    return { targetTable: "service_categories", status: "IMPORTED" as const, mappedData: category, targetRecordId: category.id };
+  }
+
+  if (sourceType === "INVENTORY_CSV") {
+    const itemName = pick(row, ["item_name", "item", "description", "name"]);
+    if (!itemName) throw new Error("Missing inventory item name");
+    const sku = pick(row, ["sku", "item_code", "code"]) ?? `LEGACY-${rowNumber}`;
+    const [existing] = await db.select().from(inventoryItemsTable).where(eq(inventoryItemsTable.sku, sku)).limit(1);
+    if (existing) return { targetTable: "inventory_items", status: "SKIPPED" as const, mappedData: existing, targetRecordId: existing.id };
+    const [item] = await db.insert(inventoryItemsTable).values({
+      itemName,
+      category: pick(row, ["category", "type"]) ?? "Legacy Import",
+      sku,
+      quantityAvailable: intValue(pick(row, ["quantity_available", "qty", "quantity", "stock"]), 0),
+      unitCost: money(pick(row, ["unit_cost", "cost", "buying_price"])),
+      sellingPrice: money(pick(row, ["selling_price", "price", "unit_rate", "rate"])),
+      supplier: pick(row, ["supplier", "vendor"]),
+      reorderLevel: intValue(pick(row, ["reorder_level", "minimum_stock"]), 0),
+    }).returning();
+    return { targetTable: "inventory_items", status: "IMPORTED" as const, mappedData: item, targetRecordId: item.id };
+  }
+
+  if (sourceType === "QUOTATIONS_CSV") {
+    const client = await findOrCreateClient(pick(row, ["client", "client_name", "customer", "name"]) ?? "Unknown Legacy Client", actorUserId);
+    const quoteNumber = pick(row, ["quote_number", "quotation_number", "quotation_no", "quote_no", "number"]) ?? `LEG-Q-${rowNumber}`;
+    const [existing] = await db.select().from(quotationsTable).where(eq(quotationsTable.quoteNumber, quoteNumber)).limit(1);
+    if (existing) return { targetTable: "quotations", status: "SKIPPED" as const, mappedData: existing, targetRecordId: existing.id };
+    const total = money(pick(row, ["grand_total", "total", "amount", "quote_total"]));
+    const subtotal = money(pick(row, ["subtotal", "amount_before_vat"]) ?? total);
+    const [quotation] = await db.insert(quotationsTable).values({
+      quoteNumber,
+      clientId: client.id,
+      projectName: pick(row, ["project_name", "project", "site", "description"]) ?? quoteNumber,
+      scopeOfSupply: pick(row, ["scope_of_supply", "scope", "description", "notes"]) ?? "Legacy imported quotation",
+      subtotal,
+      vatAmount: money(pick(row, ["vat", "vat_amount", "tax"])),
+      grandTotal: total,
+      status: statusForQuotation(pick(row, ["status"])),
+      preparedBy: pick(row, ["prepared_by", "created_by"]),
+    }).returning();
+    const itemDescription = pick(row, ["item", "description", "scope", "project_name"]);
+    if (itemDescription) {
+      await db.insert(quotationItemsTable).values({
+        quotationId: quotation.id,
+        description: itemDescription,
+        quantity: intValue(pick(row, ["quantity", "qty"]), 1),
+        unitRate: subtotal,
+        vatAmount: money(pick(row, ["vat", "vat_amount", "tax"])),
+        totalAmount: total,
+      });
+    }
+    return { targetTable: "quotations", status: "IMPORTED" as const, mappedData: quotation, targetRecordId: quotation.id };
+  }
+
+  if (sourceType === "INVOICES_CSV") {
+    const client = await findOrCreateClient(pick(row, ["client", "client_name", "customer", "name"]) ?? "Unknown Legacy Client", actorUserId);
+    const invoiceNumber = pick(row, ["invoice_number", "invoice_no", "inv_no", "number"]) ?? `LEG-INV-${rowNumber}`;
+    const [existing] = await db.select().from(invoicesTable).where(eq(invoicesTable.invoiceNumber, invoiceNumber)).limit(1);
+    if (existing) return { targetTable: "invoices", status: "SKIPPED" as const, mappedData: existing, targetRecordId: existing.id };
+    const total = Number(money(pick(row, ["grand_total", "total", "amount", "invoice_total"])));
+    const paid = Number(money(pick(row, ["amount_paid", "paid", "received"]))) || 0;
+    const [invoice] = await db.insert(invoicesTable).values({
+      invoiceNumber,
+      clientId: client.id,
+      subtotal: money(pick(row, ["subtotal", "amount_before_vat"]) ?? String(total)),
+      vatAmount: money(pick(row, ["vat", "vat_amount", "tax"])),
+      grandTotal: total.toFixed(2),
+      amountPaid: paid.toFixed(2),
+      balanceDue: Math.max(total - paid, 0).toFixed(2),
+      status: statusForInvoice(pick(row, ["status"]), total, paid),
+      notes: pick(row, ["notes", "remarks", "description"]),
+    }).returning();
+    if (paid > 0) {
+      await db.insert(paymentsTable).values({
+        invoiceId: invoice.id,
+        amount: paid.toFixed(2),
+        paymentMethod: pick(row, ["payment_method", "method"]) ?? "LEGACY",
+        paymentReference: pick(row, ["payment_reference", "reference", "receipt"]),
+        notes: "Imported from legacy invoice data",
+      });
+    }
+    return { targetTable: "invoices", status: "IMPORTED" as const, mappedData: invoice, targetRecordId: invoice.id };
+  }
+
+  if (sourceType === "INVOICE_ITEMS_CSV") {
+    const invoiceNumber = pick(row, ["invoice_number", "invoice_no", "inv_no"]);
+    if (!invoiceNumber) throw new Error("Missing invoice number for invoice item");
+    const [invoice] = await db.select().from(invoicesTable).where(eq(invoicesTable.invoiceNumber, invoiceNumber)).limit(1);
+    if (!invoice) throw new Error(`Invoice not found: ${invoiceNumber}`);
+    const total = money(pick(row, ["total_amount", "total", "amount"]));
+    const [item] = await db.insert(invoiceItemsTable).values({
+      invoiceId: invoice.id,
+      itemCode: pick(row, ["item_code", "code", "sku"]),
+      description: pick(row, ["description", "item", "name"]) ?? "Legacy imported invoice item",
+      quantity: intValue(pick(row, ["quantity", "qty"]), 1),
+      unitRate: money(pick(row, ["unit_rate", "rate", "price"]) ?? total),
+      vatAmount: money(pick(row, ["vat", "vat_amount", "tax"])),
+      totalAmount: total,
+    }).returning();
+    return { targetTable: "invoice_items", status: "IMPORTED" as const, mappedData: item, targetRecordId: item.id };
+  }
+
+  if (sourceType === "TASK_BOARD_CSV") {
+    const subject = pick(row, ["subject", "task", "item", "client", "name", "pending_sites", "quotation_to_make", "lead_follow_up", "invoice_to_make", "vasuli", "work_done", "to_meet_visit", "amc", "approved"]);
+    if (!subject) return { targetTable: "follow_ups", status: "SKIPPED" as const, mappedData: row, targetRecordId: null };
+    const bucket = pick(row, ["bucket", "category", "column", "section"]) ?? "Legacy Task Board";
+    const [followUp] = await db.insert(followUpsTable).values({
+      assignedTo: actorUserId ?? "SYSTEM",
+      dueDate: new Date(Date.now() + 7 * 24 * 60 * 60 * 1000),
+      subject: `${bucket}: ${subject}`,
+      notes: JSON.stringify(row),
+      priority: bucket.toLowerCase().includes("priority") ? "HIGH" : "MEDIUM",
+      status: bucket.toLowerCase().includes("work_done") ? "DONE" : "PENDING",
+      createdBy: actorUserId,
+    }).returning();
+    return { targetTable: "follow_ups", status: "IMPORTED" as const, mappedData: followUp, targetRecordId: followUp.id };
+  }
+
+  throw new Error(`Unsupported import source type: ${sourceType}`);
+}
+
+router.get("/history", authenticate, async (_req, res) => {
+  const batches = await db.select().from(importBatchesTable).orderBy(desc(importBatchesTable.createdAt)).limit(100);
+  res.json(batches);
+});
+
+router.get("/:id/rows", authenticate, async (req, res) => {
+  const rows = await db.select().from(importRowsTable).where(eq(importRowsTable.batchId, String(req.params.id))).orderBy(importRowsTable.rowNumber).limit(500);
+  res.json(rows);
+});
+
+router.post("/preview", authenticate, async (req, res) => {
+  const { sourceType, content } = req.body as { sourceType?: ImportSourceType; content?: string };
+  if (!sourceType || !content) { res.status(400).json({ error: "sourceType and content are required" }); return; }
+  const rows = sourceType === "TASK_BOARD_PDF" ? [] : parseCsv(content);
+  res.json({ sourceType, totalRows: rows.length, previewRows: rows.slice(0, 10), targetModule: classifyTarget(sourceType) });
+});
+
+router.post("/process", authenticate, async (req, res) => {
+  const { fileName, sourceType, content, notes } = req.body as { fileName?: string; sourceType?: ImportSourceType; content?: string; notes?: string };
+  if (!fileName || !sourceType || !content) { res.status(400).json({ error: "fileName, sourceType and content are required" }); return; }
+
+  const user = (req as any).user as { userId?: string; email?: string } | undefined;
+  const rows = sourceType === "TASK_BOARD_PDF" ? [{ fileName, note: "PDF uploaded for manual extraction" }] as CsvRow[] : parseCsv(content);
+  const [batch] = await db.insert(importBatchesTable).values({
+    sourceFileName: fileName,
+    sourceType,
+    targetModule: classifyTarget(sourceType),
+    totalRows: rows.length,
+    status: sourceType === "TASK_BOARD_PDF" ? "REVIEW_REQUIRED" : "PROCESSING",
+    uploadedBy: user?.userId,
+    notes,
+  }).returning();
+
+  let importedRows = 0;
+  let skippedRows = 0;
+  let errorRows = 0;
+  let reviewRows = 0;
+
+  for (let i = 0; i < rows.length; i += 1) {
+    const row = rows[i];
+    try {
+      const result = await processRow(sourceType, row, i + 2, user?.userId);
+      if (result.status === "IMPORTED") importedRows += 1;
+      if (result.status === "SKIPPED") skippedRows += 1;
+      if (result.status === "REVIEW_REQUIRED") reviewRows += 1;
+      await db.insert(importRowsTable).values({
+        batchId: batch.id,
+        rowNumber: i + 2,
+        rawData: row,
+        mappedData: result.mappedData,
+        status: result.status,
+        targetTable: result.targetTable,
+        targetRecordId: result.targetRecordId,
+      });
+    } catch (error) {
+      errorRows += 1;
+      await db.insert(importRowsTable).values({
+        batchId: batch.id,
+        rowNumber: i + 2,
+        rawData: row,
+        status: "ERROR",
+        targetTable: classifyTarget(sourceType),
+        errorMessage: error instanceof Error ? error.message : String(error),
+      });
+    }
+  }
+
+  const finalStatus = errorRows > 0 && importedRows > 0 ? "PARTIAL" : errorRows > 0 ? "FAILED" : reviewRows > 0 ? "REVIEW_REQUIRED" : "IMPORTED";
+  const [updated] = await db.update(importBatchesTable).set({
+    importedRows,
+    skippedRows,
+    errorRows,
+    status: finalStatus,
+  }).where(eq(importBatchesTable.id, batch.id)).returning();
+
+  res.status(201).json(updated);
+});
+
+router.delete("/:id", authenticate, async (req, res) => {
+  const batchId = String(req.params.id);
+  await db.delete(importRowsTable).where(eq(importRowsTable.batchId, batchId));
+  await db.delete(importBatchesTable).where(eq(importBatchesTable.id, batchId));
+  res.status(204).end();
+});
+
+export default router;
