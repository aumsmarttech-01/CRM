+import { useMemo, useState } from "react";
+import { useMutation, useQuery, useQueryClient } from "@tanstack/react-query";
+import { Upload, Database, AlertTriangle, CheckCircle2, FileText, RefreshCcw } from "lucide-react";
+import { Badge } from "@/components/ui/badge";
+import { Button } from "@/components/ui/button";
+import { Card, CardContent, CardHeader, CardTitle } from "@/components/ui/card";
+import { Input } from "@/components/ui/input";
+import { Textarea } from "@/components/ui/textarea";
+import { useAuth } from "@/lib/auth";
+
+type SourceType =
+  | "CLIENTS_CSV"
+  | "QUOTATIONS_CSV"
+  | "INVOICES_CSV"
+  | "INVOICE_ITEMS_CSV"
+  | "INVENTORY_CSV"
+  | "SERVICE_CATEGORIES_CSV"
+  | "TASK_BOARD_CSV"
+  | "TASK_BOARD_PDF";
+
+type ImportBatch = {
+  id: string;
+  sourceFileName: string;
+  sourceType: string;
+  targetModule: string;
+  status: string;
+  totalRows: number;
+  importedRows: number;
+  skippedRows: number;
+  errorRows: number;
+  notes?: string | null;
+  createdAt: string;
+};
+
+type PreviewResult = {
+  sourceType: SourceType;
+  totalRows: number;
+  previewRows: Record<string, string>[];
+  targetModule: string;
+};
+
+function apiUrl(path: string) {
+  return `${import.meta.env.BASE_URL.replace(/\/$/, "")}/api${path}`;
+}
+
+const importTypes: { value: SourceType; label: string; description: string }[] = [
+  { value: "CLIENTS_CSV", label: "Clients CSV", description: "Import client master records." },
+  { value: "QUOTATIONS_CSV", label: "Quotation.csv", description: "Import quotations and quotation summary items." },
+  { value: "INVOICES_CSV", label: "Invoices.csv", description: "Import invoice headers and payment totals." },
+  { value: "INVOICE_ITEMS_CSV", label: "Invoice Items CSV", description: "Import invoice line items after invoice headers." },
+  { value: "INVENTORY_CSV", label: "Items.csv", description: "Import inventory items and stock balances." },
+  { value: "SERVICE_CATEGORIES_CSV", label: "Service Categories CSV", description: "Seed CRM service categories." },
+  { value: "TASK_BOARD_CSV", label: "Task Board CSV", description: "Import task-board items into follow-ups." },
+  { value: "TASK_BOARD_PDF", label: "AumSmart Quotes PDF", description: "Store PDF task-board upload for review/manual extraction." },
+];
+
+function statusBadge(status: string) {
+  if (status === "IMPORTED") return <Badge className="bg-green-100 text-green-800 dark:bg-green-900 dark:text-green-300">Imported</Badge>;
+  if (status === "PARTIAL") return <Badge className="bg-yellow-100 text-yellow-800 dark:bg-yellow-900 dark:text-yellow-300">Partial</Badge>;
+  if (status === "FAILED") return <Badge className="bg-red-100 text-red-800 dark:bg-red-900 dark:text-red-300">Failed</Badge>;
+  if (status === "REVIEW_REQUIRED") return <Badge variant="outline">Review Required</Badge>;
+  return <Badge variant="secondary">{status}</Badge>;
+}
+
+export default function AdminImports() {
+  const { token } = useAuth();
+  const queryClient = useQueryClient();
+  const [sourceType, setSourceType] = useState<SourceType>("QUOTATIONS_CSV");
+  const [fileName, setFileName] = useState("");
+  const [content, setContent] = useState("");
+  const [notes, setNotes] = useState("");
+  const [preview, setPreview] = useState<PreviewResult | null>(null);
+  const [message, setMessage] = useState<string | null>(null);
+
+  const headers = useMemo(() => ({ Authorization: `Bearer ${token}`, "Content-Type": "application/json" }), [token]);
+
+  const history = useQuery<ImportBatch[]>({
+    queryKey: ["data-imports", "history"],
+    queryFn: async () => {
+      const res = await fetch(apiUrl("/data-imports/history"), { headers });
+      if (!res.ok) throw new Error("Failed to load import history");
+      return res.json();
+    },
+    enabled: Boolean(token),
+  });
+
+  const previewMutation = useMutation({
+    mutationFn: async () => {
+      const res = await fetch(apiUrl("/data-imports/preview"), {
+        method: "POST",
+        headers,
+        body: JSON.stringify({ sourceType, content }),
+      });
+      if (!res.ok) throw new Error((await res.json()).error ?? "Preview failed");
+      return res.json() as Promise<PreviewResult>;
+    },
+    onSuccess: (data) => {
+      setPreview(data);
+      setMessage(`Preview ready: ${data.totalRows} rows targeting ${data.targetModule}.`);
+    },
+    onError: (error) => setMessage(error instanceof Error ? error.message : String(error)),
+  });
+
+  const processMutation = useMutation({
+    mutationFn: async () => {
+      const res = await fetch(apiUrl("/data-imports/process"), {
+        method: "POST",
+        headers,
+        body: JSON.stringify({ fileName: fileName || "uploaded-file", sourceType, content, notes }),
+      });
+      if (!res.ok) throw new Error((await res.json()).error ?? "Import failed");
+      return res.json() as Promise<ImportBatch>;
+    },
+    onSuccess: (batch) => {
+      setMessage(`Import ${batch.status}: ${batch.importedRows} imported, ${batch.skippedRows} skipped, ${batch.errorRows} errors.`);
+      setPreview(null);
+      queryClient.invalidateQueries({ queryKey: ["data-imports", "history"] });
+    },
+    onError: (error) => setMessage(error instanceof Error ? error.message : String(error)),
+  });
+
+  async function handleFile(file?: File) {
+    if (!file) return;
+    setFileName(file.name);
+    if (file.type === "application/pdf" || file.name.toLowerCase().endsWith(".pdf")) {
+      setSourceType("TASK_BOARD_PDF");
+      setContent(`PDF file selected: ${file.name}. Use the parsed legacy task-board CSV for automatic row import, or keep this batch as review-required evidence.`);
+      setMessage("PDF selected. This will be stored as review-required; use CSV for automatic import.");
+      return;
+    }
+    const text = await file.text();
+    setContent(text);
+    setMessage(`Loaded ${file.name}. Select the correct import type, then preview.`);
+  }
+
+  return (
+    <div className="space-y-6">
+      <div className="flex items-center justify-between">
+        <div>
+          <h2 className="text-3xl font-bold tracking-tight text-foreground">Data Imports</h2>
+          <p className="text-muted-foreground">Render legacy quotations, invoices, items, clients, and task-board data into the CRM/ERP.</p>
+        </div>
+        <Button variant="outline" onClick={() => history.refetch()} disabled={history.isFetching}>
+          <RefreshCcw className="mr-2 h-4 w-4" /> Refresh
+        </Button>
+      </div>
+
+      <div className="grid gap-4 md:grid-cols-4">
+        <Card>
+          <CardContent className="p-4 flex items-center gap-3"><Database className="h-5 w-5" /><div><p className="text-xs text-muted-foreground">Batches</p><p className="text-2xl font-bold">{history.data?.length ?? 0}</p></div></CardContent>
+        </Card>
+        <Card>
+          <CardContent className="p-4 flex items-center gap-3"><CheckCircle2 className="h-5 w-5" /><div><p className="text-xs text-muted-foreground">Imported Rows</p><p className="text-2xl font-bold">{history.data?.reduce((s, b) => s + b.importedRows, 0) ?? 0}</p></div></CardContent>
+        </Card>
+        <Card>
+          <CardContent className="p-4 flex items-center gap-3"><AlertTriangle className="h-5 w-5" /><div><p className="text-xs text-muted-foreground">Error Rows</p><p className="text-2xl font-bold">{history.data?.reduce((s, b) => s + b.errorRows, 0) ?? 0}</p></div></CardContent>
+        </Card>
+        <Card>
+          <CardContent className="p-4 flex items-center gap-3"><FileText className="h-5 w-5" /><div><p className="text-xs text-muted-foreground">Review Needed</p><p className="text-2xl font-bold">{history.data?.filter((b) => b.status === "REVIEW_REQUIRED").length ?? 0}</p></div></CardContent>
+        </Card>
+      </div>
+
+      <Card>
+        <CardHeader><CardTitle>Upload and Process Legacy File</CardTitle></CardHeader>
+        <CardContent className="space-y-4">
+          <div className="grid gap-4 md:grid-cols-3">
+            <div className="space-y-2">
+              <label className="text-sm font-medium">File</label>
+              <Input type="file" accept=".csv,.txt,.pdf" onChange={(event) => handleFile(event.target.files?.[0])} />
+              <p className="text-xs text-muted-foreground">Use CSV for automatic import. PDF is held for review.</p>
+            </div>
+            <div className="space-y-2">
+              <label className="text-sm font-medium">Import Type</label>
+              <select className="w-full rounded-md border bg-background px-3 py-2 text-sm" value={sourceType} onChange={(event) => setSourceType(event.target.value as SourceType)}>
+                {importTypes.map((type) => <option key={type.value} value={type.value}>{type.label}</option>)}
+              </select>
+              <p className="text-xs text-muted-foreground">{importTypes.find((type) => type.value === sourceType)?.description}</p>
+            </div>
+            <div className="space-y-2">
+              <label className="text-sm font-medium">Notes</label>
+              <Input value={notes} onChange={(event) => setNotes(event.target.value)} placeholder="Optional import note" />
+            </div>
+          </div>
+
+          <Textarea className="min-h-40 font-mono text-xs" value={content} onChange={(event) => setContent(event.target.value)} placeholder="CSV content appears here. You can paste CSV manually if needed." />
+
+          <div className="flex gap-2">
+            <Button variant="outline" onClick={() => previewMutation.mutate()} disabled={!content || previewMutation.isPending || sourceType === "TASK_BOARD_PDF"}>Preview</Button>
+            <Button onClick={() => processMutation.mutate()} disabled={!content || processMutation.isPending}>
+              <Upload className="mr-2 h-4 w-4" /> Process Import
+            </Button>
+          </div>
+
+          {message && <div className="rounded-md border bg-muted/50 px-3 py-2 text-sm">{message}</div>}
+        </CardContent>
+      </Card>
+
+      {preview && (
+        <Card>
+          <CardHeader><CardTitle>Preview: {preview.totalRows} Rows → {preview.targetModule}</CardTitle></CardHeader>
+          <CardContent>
+            <div className="overflow-auto rounded-md border">
+              <table className="w-full text-xs">
+                <thead className="bg-muted/50">
+                  <tr>{Object.keys(preview.previewRows[0] ?? {}).map((key) => <th key={key} className="px-3 py-2 text-left font-medium">{key}</th>)}</tr>
+                </thead>
+                <tbody>
+                  {preview.previewRows.map((row, index) => (
+                    <tr key={index} className="border-t">
+                      {Object.keys(preview.previewRows[0] ?? {}).map((key) => <td key={key} className="px-3 py-2 align-top">{row[key]}</td>)}
+                    </tr>
+                  ))}
+                </tbody>
+              </table>
+            </div>
+          </CardContent>
+        </Card>
+      )}
+
+      <Card>
+        <CardHeader><CardTitle>Import History</CardTitle></CardHeader>
+        <CardContent>
+          <div className="overflow-auto rounded-md border">
+            <table className="w-full text-sm">
+              <thead className="bg-muted/50 text-xs uppercase text-muted-foreground">
+                <tr>
+                  <th className="px-4 py-3 text-left">File</th>
+                  <th className="px-4 py-3 text-left">Type</th>
+                  <th className="px-4 py-3 text-left">Status</th>
+                  <th className="px-4 py-3 text-right">Rows</th>
+                  <th className="px-4 py-3 text-right">Imported</th>
+                  <th className="px-4 py-3 text-right">Skipped</th>
+                  <th className="px-4 py-3 text-right">Errors</th>
+                  <th className="px-4 py-3 text-left">Created</th>
+                </tr>
+              </thead>
+              <tbody className="divide-y">
+                {history.data?.map((batch) => (
+                  <tr key={batch.id}>
+                    <td className="px-4 py-3 font-medium">{batch.sourceFileName}</td>
+                    <td className="px-4 py-3">{batch.sourceType}</td>
+                    <td className="px-4 py-3">{statusBadge(batch.status)}</td>
+                    <td className="px-4 py-3 text-right">{batch.totalRows}</td>
+                    <td className="px-4 py-3 text-right">{batch.importedRows}</td>
+                    <td className="px-4 py-3 text-right">{batch.skippedRows}</td>
+                    <td className="px-4 py-3 text-right">{batch.errorRows}</td>
+                    <td className="px-4 py-3">{new Date(batch.createdAt).toLocaleString()}</td>
+                  </tr>
+                ))}
+                {history.data?.length === 0 && <tr><td colSpan={8} className="px-4 py-8 text-center text-muted-foreground">No imports yet.</td></tr>}
+              </tbody>
+            </table>
+          </div>
+        </CardContent>
+      </Card>
+    </div>
+  );
+}
