+import { index, integer, jsonb, pgEnum, pgTable, text, timestamp } from "drizzle-orm/pg-core";
+import { createInsertSchema } from "drizzle-zod";
+import { z } from "zod/v4";
+
+export const importBatchStatusEnum = pgEnum("import_batch_status", [
+  "UPLOADED",
+  "VALIDATED",
+  "PROCESSING",
+  "IMPORTED",
+  "PARTIAL",
+  "FAILED",
+  "REVIEW_REQUIRED",
+]);
+
+export const importRowStatusEnum = pgEnum("import_row_status", [
+  "PENDING",
+  "IMPORTED",
+  "SKIPPED",
+  "ERROR",
+  "REVIEW_REQUIRED",
+]);
+
+export const importBatchesTable = pgTable("import_batches", {
+  id: text("id").primaryKey().$defaultFn(() => crypto.randomUUID()),
+  sourceFileName: text("source_file_name").notNull(),
+  sourceType: text("source_type").notNull(),
+  targetModule: text("target_module").notNull(),
+  status: importBatchStatusEnum("status").notNull().default("UPLOADED"),
+  totalRows: integer("total_rows").notNull().default(0),
+  importedRows: integer("imported_rows").notNull().default(0),
+  skippedRows: integer("skipped_rows").notNull().default(0),
+  errorRows: integer("error_rows").notNull().default(0),
+  uploadedBy: text("uploaded_by"),
+  notes: text("notes"),
+  createdAt: timestamp("created_at", { withTimezone: true }).notNull().defaultNow(),
+  updatedAt: timestamp("updated_at", { withTimezone: true }).notNull().defaultNow().$onUpdate(() => new Date()),
+}, (table) => ({
+  statusIdx: index("import_batches_status_idx").on(table.status),
+  sourceTypeIdx: index("import_batches_source_type_idx").on(table.sourceType),
+  createdAtIdx: index("import_batches_created_at_idx").on(table.createdAt),
+}));
+
+export const importRowsTable = pgTable("import_rows", {
+  id: text("id").primaryKey().$defaultFn(() => crypto.randomUUID()),
+  batchId: text("batch_id").notNull(),
+  rowNumber: integer("row_number").notNull(),
+  targetTable: text("target_table"),
+  targetRecordId: text("target_record_id"),
+  status: importRowStatusEnum("status").notNull().default("PENDING"),
+  rawData: jsonb("raw_data").notNull(),
+  mappedData: jsonb("mapped_data"),
+  errorMessage: text("error_message"),
+  createdAt: timestamp("created_at", { withTimezone: true }).notNull().defaultNow(),
+  updatedAt: timestamp("updated_at", { withTimezone: true }).notNull().defaultNow().$onUpdate(() => new Date()),
+}, (table) => ({
+  batchIdx: index("import_rows_batch_idx").on(table.batchId),
+  statusIdx: index("import_rows_status_idx").on(table.status),
+  targetIdx: index("import_rows_target_idx").on(table.targetTable, table.targetRecordId),
+}));
+
+export const insertImportBatchSchema = createInsertSchema(importBatchesTable).omit({ id: true, createdAt: true, updatedAt: true });
+export const insertImportRowSchema = createInsertSchema(importRowsTable).omit({ id: true, createdAt: true, updatedAt: true });
+
+export type ImportBatch = typeof importBatchesTable.$inferSelect;
+export type InsertImportBatch = z.infer<typeof insertImportBatchSchema>;
+export type ImportRow = typeof importRowsTable.$inferSelect;
+export type InsertImportRow = z.infer<typeof insertImportRowSchema>;
