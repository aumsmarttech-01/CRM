{
  "name": "aum-smart-tech-crm",
  "version": "1.0.0",
  "private": true,
  "description": "CRM for AUM Smart Tech Ltd built with React, Express, PostgreSQL, Prisma, JWT, and bcrypt.",
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev --workspace server\" \"npm run dev --workspace client\"",
    "server:dev": "npm run dev --workspace server",
    "client:dev": "npm run dev --workspace client",
    "build": "npm run build --workspace client",
    "db:generate": "npm run prisma:generate --workspace server",
    "db:migrate": "npm run prisma:migrate --workspace server",
    "db:deploy": "npm run prisma:deploy --workspace server",
    "db:seed": "npm run seed --workspace server",
    "backup": "npm run backup --workspace server",
    "restore": "npm run restore --workspace server --"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
