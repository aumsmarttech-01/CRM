# AUM Smart Tech CRM - server environment template
# Copy this to server/.env locally, or add these values as Replit Secrets.
# Never commit real passwords, service-role keys, JWT secrets, SMTP passwords, or API keys.

NODE_ENV=development
PORT=4000
CLIENT_ORIGIN=http://localhost:5173

# Supabase PostgreSQL
# App/runtime connection should use the transaction-mode pooler in production/Replit.
DATABASE_URL=postgresql://postgres.uhdrortamsewvrtqtspv:[YOUR-PASSWORD]@aws-0-eu-west-1.pooler.supabase.com:6543/postgres?pgbouncer=true

# Migration/admin connection should use session-mode pooler or native direct connection.
DIRECT_URL=postgresql://postgres:[YOUR-PASSWORD]@db.uhdrortamsewvrtqtspv.supabase.co:5432/postgres

# Supabase API/Auth
SUPABASE_URL=https://uhdrortamsewvrtqtspv.supabase.co
SUPABASE_PUBLISHABLE_KEY=your-supabase-publishable-key
SUPABASE_SECRET_KEY=your-server-only-supabase-secret-key
SUPABASE_JWKS_URL=https://uhdrortamsewvrtqtspv.supabase.co/auth/v1/.well-known/jwks.json

# JWT / auth
JWT_SECRET=replace-with-a-long-random-secret
JWT_ACCESS_SECRET=replace-with-a-long-random-access-secret
JWT_REFRESH_SECRET=replace-with-a-long-random-refresh-secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d
REFRESH_COOKIE_NAME=aum_refresh_token
COOKIE_SECURE=true

# Security
TRUST_PROXY=1
FORCE_HTTPS=true
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=300
AUTH_RATE_LIMIT_MAX=20
AUDIT_LOG_ENABLED=true
FIELD_ENCRYPTION_KEY=

# Automation
AUTOMATION_RUNNER_ENABLED=true
AUTOMATION_INTERVAL_MS=900000
N8N_WEBHOOK_URL=
AUTOMATION_WEBHOOK_TIMEOUT_MS=5000

# Notifications
NOTIFICATION_EMAIL_TO=aumsmarttech@gmail.com
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ADMIN_TO=
WHATSAPP_GRAPH_VERSION=v20.0
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_APP_SECRET=
WHATSAPP_DEFAULT_COUNTRY_CODE=254
WHATSAPP_FEEDBACK_URL=
CLIENT_PORTAL_URL=

# Backups
BACKUP_ENABLED=true
BACKUP_TIME_UTC=22:00
BACKUP_FREQUENCY=weekly
BACKUP_WEEKDAY_UTC=0
BACKUP_DIR=backups
BACKUP_RETENTION_DAYS=14
BACKUP_OFFSITE_URL=
BACKUP_OFFSITE_TOKEN=
BACKUP_OFFSITE_DIR=
BACKUP_S3_BUCKET=
BACKUP_S3_PREFIX=aum-smart-tech-crm
AWS_REGION=us-east-1
PG_DUMP_PATH=pg_dump
PG_RESTORE_PATH=pg_restore

# AI workflow support
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
